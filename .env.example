# ---- required ----
# Public hostname; DNS A/AAAA must point at this VPS. Caddy gets a cert for it.
DOMAIN=builder.example.com

# The builder repo the broker dispatches to.
GITHUB_REPO=gtxaspec/thingino-web-builder

# Token the broker uses to dispatch builds + manage releases/runs on GITHUB_REPO.
# Fine-grained PAT scoped to GITHUB_REPO with: Contents R/W, Actions R/W, Metadata R.
# (Resolving thingino's commit is an unauthenticated public read, so no other-repo
#  access is needed.) A classic PAT with `repo` + `workflow` also works. See DEPLOY.md.
GITHUB_TOKEN=github_pat_xxxxxxxx

# ---- admin (run ./setup.sh to generate these) ----
ADMIN_TOKEN=
ADMIN_TOTP_SECRET=

# ---- optional tuning (defaults shown) ----
#PER_USER_HOURLY_LIMIT=2
#PER_IP_HOURLY_LIMIT=3
#GLOBAL_HOURLY_LIMIT=20
#MAX_CONCURRENT_BUILDS=6
#RETENTION_SECS=1800
#ROLLING_TAG=web-builds
#THINGINO_REPO=themactep/thingino-firmware
#THINGINO_REF=master
